{
  "ConnectionStrings": {
    "AuthDb": "Server=xxxxxxx,xxx;Database=Auth;User Id=sa;xxxxxxx;TrustServerCertificate=True;"
  },
  "Jwt": {
    "Issuer": "auth-service",
    "Audience": "auth-clients",
    "SigningKey": "change-this-super-secret-key-change-this-before-production",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7
  },
  "Seed": {
    "AdminEmail": "admin@local.dev",
    "AdminUserName": "admin",
    "AdminPassword": "Admin@123456",
    "DefaultTenantName": "Default Tenant",
    "DefaultTenantSlug": "default"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}

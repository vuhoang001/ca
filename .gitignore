*.code-workspace

# NuGet Packages
*.nupkg
*.snupkg
# NuGet Symbol Packages
*.snupkg
# The packages folder can be ignored because of Package Restore
**/packages/*
# except build/, which is used as an MSBuild target.
!**/packages/build/
# Uncomment if necessary however generally it's not needed
#!**/packages/repositories.config
# NuGet v3's project.json files makes some of the MSBuild targets obsolete. 
# the project.json and project.lock.json files with Top-level dependencies 
# can be ignored when using newer versions of NuGet.
# Old format requires .nuget/NuGet.Config files

# Microsoft Azure Build Output
csx/
*.build.csdef

# Microsoft Azure Emulator
ecf/
rcf/

# Windows Store app package directories and files
AppPackages/
BundleArtifacts/
Package.StoreAssociation.xml
_StoreKeyFile/
*.appxbundle
*.appxupload

# Visual Studio cache files
# files ending in .cache can be ignored
*.[Cc]ache
# but keep track of directories ending in .cache
!?*.[Cc]ache/

# Others
ClientBin/
~$*
*~
_opencover_*
*.Cover
*.coveragexml
coverage/
coverage*.json
coverage*.xml
opencover*.xml

# Include NuGet Resolve so components can be registered
!NuGetFallbackFolder

# Windows Installer files from build results
*.msi
*.msix
*.msixbundle
*.msp

